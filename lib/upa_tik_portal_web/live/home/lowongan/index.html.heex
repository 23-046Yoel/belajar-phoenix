<.navbar active_tab={:lowongan} >
  <div class="py-10">
    <!-- Hero Section -->
    <header class="text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight">
        Temukan Peluang <span class="text-blue-600">Magang Terbaik</span>
      </h1>
      <p class="mt-4 text-lg max-w-2xl mx-auto">
        Akses berbagai lowongan magang eksklusif untuk mahasiswa dan tingkatkan portofolio profesionalmu sekarang.
      </p>
    </header>

    <!-- Search & Filter Bar -->
    <div class="max-w-4xl mx-auto mb-12">
      <form phx-change="search" class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <.icon name="hero-magnifying-glass" class="h-5 w-5 text-black" />
        </div>
        <input 
          type="text" 
          name="query" 
          placeholder="Cari posisi atau departmen..." 
          class="block w-full pl-10 pr-3 py-4 border text-black border-slate-200 rounded-2xl leading-5 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all"
        />
      </form>
    </div>

    <!-- Job Grid -->
    <div :if={@any_lowongan?} id="lowongan-list" phx-update="stream" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div 
        :for={{id, item} <- @streams.lowongans} 
        id={id} 
        class="border border-slate-200 bg-white dark:bg-slate-900 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all group flex flex-col justify-between"
      >
        <div>
          <div class="flex justify-between items-start mb-4">
            <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
              <%= item.department %>
            </span>
            <span class="text-xs flex items-center">
              <.icon name="hero-users" class="w-3 h-3 mr-1" />
              Sisa <%= item.quota %> Kuota
            </span>
          </div>

          <h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors">
            <%= item.title %>
          </h3>
          
          <p class="mt-3 text-sm line-clamp-3">
            <%= item.description %>
          </p>
        </div>

        <div class="mt-6 pt-6 border-t border-slate-50 flex items-center justify-between">
          <div class="text-xs">
             Berakhir pada: <span class="font-medium"><%= Calendar.strftime(item.closing_date, "%d %b %Y") %></span>
          </div>
          <.link 
            navigate={~p"/portal/lowongan/#{item.id}"}
            class="text-sm font-semibold text-blue-600 dark:text-blue-200 hover:text-blue-700 flex items-center"
          >
            Detail <.icon name="hero-chevron-right" class="w-4 h-4 ml-1" />
          </.link>
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div :if={!@any_lowongan?} class="text-center py-20 rounded-3xl border-2 border-dashed border-slate-200">
      <.icon name="hero-briefcase" class="mx-auto h-12 w-12 text-slate-300" />
      <h3 class="mt-4 text-lg font-semibold">Belum ada lowongan aktif</h3>
      <p class="mt-2">Coba gunakan kata kunci lain atau cek kembali nanti.</p>
    </div>
  </div>
</.navbar>