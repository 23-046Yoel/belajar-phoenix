<.navbar active_tab={:lowongan}>
  <div class="max-w-4xl mx-auto py-10 px-4">
    <!-- Breadcrumb (Navigasi Kembali) -->
    <.link navigate={~p"/portal/lowongan"} class="inline-block text-sm font-semibold leading-6 hover:text-blue-600 flex items-center mb-8">
      <.icon name="hero-arrow-left" class="w-4 h-4 mr-1" /> Kembali ke Daftar Lowongan
    </.link>

    <div class="bg-white shadow-sm rounded-2xl overflow-hidden">
        <!-- Header Banner -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 px-8 py-10 text-white">
            <div class="flex items-center gap-3 mb-4">
                <span class="inline-flex items-center rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white ring-1 ring-inset ring-white/20 backdrop-blur-sm">
                    <%= @opening.department %>
                </span>
                <span class="text-blue-100 text-sm flex items-center">
                    <.icon name="hero-users" class="w-4 h-4 mr-1" /> <%= @opening.quota %> Kuota
                </span>
            </div>
            <h1 class="text-3xl font-bold tracking-tight mb-2"><%= @opening.title %></h1>
            <p class="text-blue-100 flex items-center text-sm">
                <.icon name="hero-calendar" class="w-4 h-4 mr-2" />
                Ditutup pada: <span class="font-semibold ml-1"><%= Calendar.strftime(@opening.closing_date, "%d %B %Y") %></span>
            </p>
        </div>

        <!-- Konten Utama -->
        <div class="p-8">
            <h3 class="text-xl font-bold text-slate-900 mb-4">Deskripsi Pekerjaan</h3>
            
            <!-- Menggunakan prose untuk memformat teks panjang dengan rapi -->
            <div class="prose prose-slate max-w-none text-slate-600 mb-10 whitespace-pre-line">
                <%= @opening.description %>
            </div>

            <!-- Action Area -->
            <div class="border-t border-slate-100 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div>
                    <p class="text-sm text-slate-500">Tertarik dengan posisi ini?</p>
                    <p class="font-medium text-slate-900">Segera ajukan sebelum kuota penuh.</p>
                </div>

                <.link
                    navigate={~p"/portal/lowongan/#{@opening.id}"}
                    phx-click="ajukan_magang"
                    class="cursor-pointer w-full sm:w-auto inline-flex justify-center items-center rounded-xl bg-blue-600 px-8 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all"
                >
                Ajukan Magang Sekarang <.icon name="hero-paper-airplane" class="w-4 h-4 ml-2" />
                </.link>
            </div>
        </div>
    </div>
  </div>
</.navbar>