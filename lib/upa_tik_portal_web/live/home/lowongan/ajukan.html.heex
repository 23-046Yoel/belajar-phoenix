<.navbar active_tab={:lowongan} current_user={@user}>
    <Layouts.flash_group flash={@flash} />
    <.heading_page
        heading_text_primary="Lengkapi Data"
        heading_text_secondary="Pengajuan Magang"
        sub_heading_text="Pastikan semua link dokumen dapat diakses secara publik."
    />
    <div class="max-w-7xl mx-auto shadow-sm ring-1 ring-slate-200 rounded-xl p-8 mt-8">
        <div class="max-w-7xl mx-auto">
            <.link navigate={~p"/portal/lowongan"} class="text-sm font-semibold leading-6 hover:text-blue-500 flex items-center mb-6">
            <.icon name="hero-arrow-left" class="w-4 h-4 mr-1" /> Kembali ke Lowongan
            </.link>
        </div>

        <.simple_form for={@form} phx-submit="save_application" phx-change="validate">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <%!-- Pendidikan --%>
                <.input field={@form[:university]} type="text" label="Universitas" placeholder="Contoh: Universitas Trunojoyo Madura" />
                <.input field={@form[:major]} type="text" label="Program Studi" placeholder="Contoh: Teknik Informatika" />

                <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6 p-6 rounded-2xl border border-zinc-200/80 shadow-sm">
  
                    <!-- Bagian CV -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold leading-6 text-zinc-800">
                        CV <span class="text-xs font-normal text-zinc-400">(PDF max 5MB)</span>
                        </label>
                        <div class="flex items-center justify-center rounded-lg border border-dashed border-zinc-300 px-4 py-3 hover:border-zinc-400 transition-colors bg-zinc-50/50">
                            <.live_file_input 
                                upload={@uploads.cv} 
                                class="block w-full text-sm text-zinc-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-zinc-800 cursor-pointer file:transition-all"
                            />
                        </div>
                        <.error :for={err <- @form[:cv_url].errors}>
                            <%= translate_error(err) %>
                        </.error>
                    </div>

                    <!-- Bagian Surat Pengantar -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold leading-6 text-zinc-800">
                        Surat Pengantar <span class="text-xs font-normal text-zinc-400">(PDF max 5MB)</span>
                        </label>
                        <div class="flex items-center justify-center rounded-lg border border-dashed border-zinc-300 px-4 py-3 hover:border-zinc-400 transition-colors bg-zinc-50/50">
                            <.live_file_input 
                                upload={@uploads.surat_pengantar} 
                                class="block w-full text-sm text-zinc-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-zinc-800 cursor-pointer file:transition-all"
                            />
                        </div>
                        <.error :for={err <- @form[:cv_url].errors}>
                            <%= translate_error(err) %>
                        </.error>
                    </div>        

                    <!-- Bagian Transkrip Nilai -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold leading-6 text-zinc-800">
                        Transkrip Nilai <span class="text-xs font-normal text-zinc-400">(PDF max 5MB)</span>
                        </label>
                        <div class="flex items-center justify-center rounded-lg border border-dashed border-zinc-300 px-4 py-3 hover:border-zinc-400 transition-colors bg-zinc-50/50">
                            <.live_file_input 
                                upload={@uploads.transkrip} 
                                class="block w-full text-sm text-zinc-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-zinc-800 cursor-pointer file:transition-all"
                            />
                        </div>
                        <.error :for={err <- @form[:cv_url].errors}>
                            <%= translate_error(err) %>
                        </.error>
                    </div>

                    <!-- Bagian Portfolio Dinamis -->
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold leading-6 text-zinc-800">Portfolio</label>
                        <div class="inline-flex w-full p-1 bg-zinc-100 rounded-lg max-w-xs border border-zinc-200">
                            <button
                                type="button"
                                phx-click="change_portfolio_mode"
                                phx-value-mode="link"
                                class={[
                                "w-1/2 py-1.5 text-xs font-medium rounded-md transition-all",
                                @portfolio_mode == "link" && "bg-white text-zinc-900 shadow-sm",
                                @portfolio_mode != "link" && "text-zinc-500 hover:text-zinc-800"
                                ]}>
                                Tautan Link
                            </button>

                            <button
                                type="button"
                                phx-click="change_portfolio_mode"
                                phx-value-mode="file"
                                class={[
                                "w-1/2 py-1.5 text-xs font-medium rounded-md transition-all",
                                @portfolio_mode == "file" && "bg-white text-zinc-900 shadow-sm",
                                @portfolio_mode != "file" && "text-zinc-500 hover:text-zinc-800"
                                ]}
                            >
                                File Dokumen
                            </button>
                        </div>

                        <!-- Conditional Input Display -->
                        <div class="mt-2">
                        <%= if @portfolio_mode == "link" do %>
                            <.input
                                field={@form[:portfolio_url]}
                                type="url"
                                placeholder="https://github.com/kamu atau https://behance.net/..."
                            />
                        <% else %>
                            <div class="flex items-center justify-center rounded-lg border border-dashed border-zinc-300 px-4 py-3 hover:border-zinc-400 transition-colors bg-zinc-50/50">
                                <.live_file_input 
                                    upload={@uploads.portfolio_file} 
                                    class="block w-full text-sm text-zinc-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-zinc-800 cursor-pointer file:transition-all"
                                />
                            </div>
                            <.error :for={err <- @form[:cv_url].errors}>
                                <%= translate_error(err) %>
                            </.error>
                        <% end %>
                        </div>
                    </div>
                </div>

                <%!-- Periode Magang --%>
                <.input field={@form[:start_date]} type="date" label="Tanggal Mulai" />
                <.input field={@form[:end_date]} type="date" label="Tanggal Berakhir" />
            </div>

            <%!-- Status disembunyikan karena defaultnya 'applied' --%>
            <.input field={@form[:status]} type="hidden" value="applied" />

            <:actions>
                <.button phx-disable-with="Menyimpan..." class="w-full cursor-pointer justify-center rounded-lg text-white py-3 bg-blue-600 hover:bg-blue-700">
                    Kirim Lamaran Sekarang
                </.button>
            </:actions>
        </.simple_form>
    </div>
</.navbar>