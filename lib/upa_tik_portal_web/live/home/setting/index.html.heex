<.navbar active_tab={:setting}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <header class="mb-10">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Pengaturan</h2>
      <p class="mt-2 text-slate-600 dark:text-slate-400">Kelola preferensi akun dan tampilan aplikasi Anda.</p>
    </header>

    <div class="space-y-6">
      <!-- Section: Tampilan -->
      <section class="bg-white dark:bg-slate-800 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700 rounded-2xl overflow-hidden">
        <div class="p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
              <.icon name="hero-paint-brush" class="w-6 h-6" />
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white">Tampilan</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">Atur tema warna antarmuka portal.</p>
            </div>
          </div>

          <div class="flex items-center justify-between py-4 border-t border-slate-100 dark:border-slate-700">
            <div>
              <p class="font-medium text-slate-900 dark:text-white">Mode Gelap</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">Mengurangi silau dan lebih nyaman di mata pada malam hari.</p>
            </div>
            
            <!-- Toggle Switch -->
            <Layouts.theme_toggle />
          </div>
        </div>
      </section>

      <!-- Section: Profil (Opsional) -->
      <section class="bg-white dark:bg-slate-800 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700 rounded-2xl p-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-700 flex items-center justify-center text-slate-600 dark:text-slate-300">
              <.icon name="hero-user" class="w-6 h-6" />
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-900 dark:text-white">Informasi Akun</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">Data mahasiswa dan instansi Anda.</p>
            </div>
          </div>
          <.link navigate={~p"/portal/profile"} class="bg-slate-100 px-4 py-2 cursor-pointer rounded-md dark:bg-slate-700 text-slate-900! dark:text-white! hover:bg-slate-200">
            Edit Profil
          </.link>
        </div>
      </section>
    </div>
  </div>
</.navbar>