<.navbar active_tab={:profile}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Profile Header Card -->
    <div class="bg-white dark:bg-slate-800 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700 rounded-3xl p-8 mb-8">
      <div class="flex flex-col md:flex-row items-center gap-6">
        <div class="relative group">
          <div class="w-24 h-24 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold shadow-lg ring-4 ring-blue-50 dark:ring-blue-900/30">
            <%= String.at(@user.name, 0) %>
          </div>
          <button class="absolute bottom-0 right-0 p-2 bg-white dark:bg-slate-700 rounded-full shadow-md border border-slate-100 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:text-blue-600">
            <.icon name="hero-camera" class="w-4 h-4" />
          </button>
        </div>
        
        <div class="text-center md:text-left flex-1">
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white"><%= @user.name %></h1>
          <div class="mt-2 flex flex-wrap justify-center md:justify-start gap-2">
            <span class="inline-flex items-center gap-1 rounded-md bg-blue-50 dark:bg-blue-900/20 px-2 py-1 text-xs font-medium text-blue-700 dark:text-blue-400 ring-1 ring-inset ring-blue-700/10">
              <.icon name="hero-academic-cap" class="w-3 h-3" /> Mahasiswa Aktif
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Form Edit Profil -->
    <div class="bg-white dark:bg-slate-800 shadow-sm ring-1 ring-slate-200 dark:ring-slate-700 rounded-3xl overflow-hidden">
      <div class="p-8">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6">Informasi Pribadi</h3>
        
        <.simple_form for={@form} phx-submit="save_profile">
            <div class="space-y-6">
                <.input 
                    field={@form[:name]} 
                    type="text" 
                    label="Nama Lengkap" 
                />

                <p class="mt-2 text-sm text-slate-500">Nama ini akan digunakan pada sertifikat dan pengajuan magang.</p>

                <!-- Email (Read Only) -->
                <div>
                    <label class="block text-sm font-semibold leading-6 text-zinc-800 dark:text-zinc-200">Email Kampus</label>
                    <div class="mt-2 p-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-500 cursor-not-allowed">
                        <%= @user.email %>
                    </div>
                </div>
            </div>

          <:actions>
            <.button class="text-white dark:text-slate-900 cursor-pointer w-full md:w-auto bg-blue-600 hover:bg-blue-700 px-8 py-2.5 rounded-md shadow-md shadow-blue-200 dark:shadow-none">
              Simpan Perubahan
            </.button>
          </:actions>
        </.simple_form>
      </div>
    </div>
  </div>
</.navbar>