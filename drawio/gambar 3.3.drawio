                <mxCell id="msg9" value="9. Respon Sukses (Notifikasi &amp;amp; Halaman Ter-update)" style="endArrow=open;dashed=1;html=1;rounded=0;strokeColor=#000000;strokeWidth=1.5;fontFamily=Times New Roman;fontSize=10;fontColor=#000000;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.96;exitDx=0;exitDy=0;entryX=1;entryY=0.96;entryDx=0;entryDy=0;" parent="1" source="web_act" target="client_act" edge="1">
