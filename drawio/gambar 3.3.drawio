                        <mxPoint x="400" y="680" as="sourcePoint"/>
                        <mxPoint x="200" y="680" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="note_flow" value="&lt;font face=&quot;Times New Roman&quot;&gt;&lt;b style=&quot;font-size: 12px;&quot;&gt;Catatan Integrasi Unggah File Minio:&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;1. &lt;b&gt;Submit Form&lt;/b&gt;: Pengguna mengirimkan keluhan lengkap dengan file lampiran fisik dari Client Browser.&lt;br/&gt;2. &lt;b&gt;Renaming UUID&lt;/b&gt;: Untuk mencegah penimpaan nama file yang sama di dalam bucket Minio, Controller/LiveView mengubah nama file asli menjadi UUID unik.&lt;br/&gt;3. &lt;b&gt;Minio Upload&lt;/b&gt;: Aplikasi Phoenix memanggil Storage Service (&lt;i&gt;UpaTikPortal.Storage.upload/2&lt;/i&gt;) untuk mentransfer berkas fisik secara asinkron ke server Minio via library ExAws (protokol HTTP S3 API).&lt;br/&gt;4. &lt;b&gt;DB Persistence&lt;/b&gt;: Setelah file aman terunggah di Minio, referensi lokasi file (Object Key/UUID) dan data teks keluhan disimpan ke PostgreSQL Database melalui Ecto.&lt;/font&gt;" style="text;html=1;strokeColor=#000000;fillColor=#FFFFFF;spacing=12;spacingTop=8;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#000000;align=left;verticalAlign=top;shadow=0;strokeWidth=1.5;fontFamily=Times New Roman;" parent="1" vertex="1">
                    <mxGeometry x="145" y="780" width="540" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="watermark" value="&lt;font face=&quot;Times New Roman&quot;&gt;&lt;span style=&quot;font-size: 10px; color: #000000;&quot;&gt;Program Studi Teknik Informatika - Portal Layanan UPA TIK&lt;/span&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Times New Roman;" parent="1" vertex="1">
                    <mxGeometry x="850" y="800" width="300" height="30" as="geometry"/>
