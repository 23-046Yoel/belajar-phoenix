        <mxCell id="edge_dec_token_no" value="[Tidak]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;fontFamily=Times New Roman;" edge="1" parent="1" source="dec_token_exists" target="plug_halt">
          <mxGeometry relative="1" as="geometry" />
