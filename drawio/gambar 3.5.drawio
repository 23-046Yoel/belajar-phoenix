                    <mxGeometry x="400" y="430" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="vol_storage" value="&lt;font face=&quot;Times New Roman&quot;&gt;&lt;b&gt;Named Volume: minio_data&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size: 9px;&quot;&gt;Host Disk: /var/lib/docker/volumes/minio_data/_data&lt;/span&gt;&lt;/font&gt;" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;fontFamily=Times New Roman;align=center;verticalAlign=middle;" parent="host_boundary" vertex="1">
                    <mxGeometry x="730" y="440" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="edge_ext_web" value="HTTP / WS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=9;fontFamily=Times New Roman;" parent="host_boundary" source="port_web" target="container_web" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_ext_db" value="SQL Conn" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=9;fontFamily=Times New Roman;" parent="host_boundary" source="port_db" target="container_db" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_ext_storage" value="S3 Console" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=9;fontFamily=Times New Roman;" parent="host_boundary" source="port_storage" target="container_storage" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_web_db" value="Database Queries (ECTO)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;fontFamily=Times New Roman;" parent="host_boundary" source="container_web" target="container_db" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_web_storage" value="S3 HTTP Upload (ExAws)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;fontFamily=Times New Roman;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" parent="host_boundary" source="container_web" target="container_storage" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_db_vol" value="Mount: /var/lib/postgresql/data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=9;fontStyle=2;labelBackgroundColor=#FFFFFF;dashed=1;fontFamily=Times New Roman;" parent="host_boundary" source="container_db" target="vol_db" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge_storage_vol" value="Mount: /data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;fontColor=#000000;fontSize=9;fontStyle=2;labelBackgroundColor=#FFFFFF;dashed=1;fontFamily=Times New Roman;" parent="host_boundary" source="container_storage" target="vol_storage" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note_docker" value="&lt;font face=&quot;Times New Roman&quot;&gt;&lt;b style=&quot;font-size: 11px;&quot;&gt;Keterangan Jaringan Kontainer Docker Compose:&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;1. &lt;b&gt;Internal Network&lt;/b&gt;: Ketiga kontainer berada dalam jaringan virtual internal yang sama (&lt;i&gt;upa-tik-network&lt;/i&gt;) sehingga kontainer &lt;i&gt;web-app&lt;/i&gt; dapat langsung berkomunikasi secara aman dengan &lt;i&gt;database&lt;/i&gt; (port 5432) dan &lt;i&gt;storage&lt;/i&gt; (port 9000) menggunakan nama host kontainernya.&lt;br/&gt;2. &lt;b&gt;Port Mapping&lt;/b&gt;: Port luar yang di-expose ke publik memungkinkan pengguna mengakses aplikasi Phoenix di port 4000, serta administrator mengakses panel manajemen Minio di port 9001.&lt;br/&gt;3. &lt;b&gt;Persistent Data&lt;/b&gt;: Data PostgreSQL dan data unggahan berkas Minio dialirkan ke volume fisik (&lt;i&gt;pg_data&lt;/i&gt; dan &lt;i&gt;minio_data&lt;/i&gt;) pada media penyimpanan server agar data tetap aman saat kontainer dimatikan/dihapus.&lt;/font&gt;" style="text;html=1;strokeColor=#000000;fillColor=#FFFFFF;spacing=12;spacingTop=6;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#000000;align=left;verticalAlign=top;shadow=0;strokeWidth=1.5;fontFamily=Times New Roman;" parent="1" vertex="1">
                    <mxGeometry x="90" y="710" width="390" height="180" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>