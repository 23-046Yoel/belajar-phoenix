# ============================================================
# ENVIRONMENT VARIABLES — UPA TIK PORTAL
# ============================================================
# Salin file ini menjadi .env dan isi dengan nilai yang benar.
# Jangan pernah commit file .env ke dalam Git!

# ------------------------------------------------------------
# Google OAuth Credentials
# Dapatkan dari: https://console.cloud.google.com/
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ------------------------------------------------------------
# Database Configuration
#
# [DEVELOPMENT] Gunakan PostgreSQL lokal:
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_HOSTNAME=localhost
# DB_DATABASE=upa_tik_portal_dev
#
# [PRODUCTION] Gunakan DATABASE_URL dari Neon.tech:
# DATABASE_URL=postgresql://username:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# ------------------------------------------------------------
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOSTNAME=localhost
DB_DATABASE=upa_tik_portal_dev

# Hanya untuk production (Koyeb/Fly.io + Neon.tech):
# DATABASE_URL=postgresql://...

# ------------------------------------------------------------
# Phoenix Production Settings
# Hanya diperlukan saat production
# Generate SECRET_KEY_BASE dengan: mix phx.gen.secret
# ------------------------------------------------------------
# SECRET_KEY_BASE=isi_dengan_hasil_mix_phx.gen.secret
# PHX_HOST=domain-anda.koyeb.app

# ------------------------------------------------------------
# MinIO / S3 / Cloudflare R2 Configuration
#
# [DEVELOPMENT] MinIO lokal:
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_HOST=127.0.0.1
# MINIO_PORT=9000
# MINIO_BUCKET=upa-tik-uploads
# MINIO_ENDPOINT=http://localhost:9000
#
# [PRODUCTION] Cloudflare R2:
# MINIO_ACCESS_KEY=<R2 Access Key ID>
# MINIO_SECRET_KEY=<R2 Secret Access Key>
# MINIO_HOST=<ACCOUNT_ID>.r2.cloudflarestorage.com
# MINIO_PORT=443
# MINIO_BUCKET=upa-tik-uploads
# MINIO_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# ------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_BUCKET=upa-tik-uploads
MINIO_ENDPOINT=http://localhost:9000

# ------------------------------------------------------------
# SMTP Configuration (Gmail)
# Buat App Password Gmail di: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
